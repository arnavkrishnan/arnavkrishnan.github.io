---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
const base = '/portfolio';
const previous = 'elevator';
const next = 'hashes';
---
<BaseLayout title="Huffman Compression | ADEN Project" base={base}>
  <Pagination base={base} section="projects/aden" previous={previous} next={next} />
  <h1>Huffman Compression</h1>

  <section style="margin-bottom:1rem;">
    <p>
      Implemented Huffman coding to produce prefix-free variable-length codes based on symbol frequency. The implementation supports encoding and decoding with validation tests to ensure lossless restoration.
    </p>
  </section>
  </section>

  <section id="reflections" style="margin-bottom:1rem;">
    <h2>Reflections</h2>
    <p>
      <strong>Reflection:</strong>
      <a href={`${base}/documents/reflections/html/${encodeURIComponent('Reflection - HuffmanCompression 1.html')}`} target="_blank" rel="noopener">HTML</a>
      {' '}|{' '}
      <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Reflection - HuffmanCompression 1.pdf')}`} download target="_blank" rel="noopener">PDF</a>
    </p>
    <p><a href={`${base}/aden-course`} style="color:#0055aa; text-decoration:underline;">← Back to ADEN Course</a></p>
  </section>
</BaseLayout>