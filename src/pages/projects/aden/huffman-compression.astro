---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
const base = '/portfolio';
const previous = 'elevator';
const next = 'hashes';
---
<BaseLayout title="Huffman Compression | ADEN Project" base={base}>
  <Pagination base={base} section="projects/aden" previous={previous} next={next} />
  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
    <h1>Huffman Compression</h1>

    <section style="margin-bottom:1rem;">
      <p>
        Implemented Huffman coding to produce prefix-free variable-length codes based on symbol frequency. The implementation supports encoding and decoding with validation tests to ensure lossless restoration.
      </p>
    </section>

    <section id="reflections" style="margin-bottom:1rem;">
      <h2>Reflections</h2>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-bottom:0.75rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Huffman Compression Reflection</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Reflection - HuffmanCompression 1.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
            <button type="button" aria-expanded="false" class="toggle-btn" data-target={`ref-huffman-1`} style="padding:0.35rem 0.5rem; border-radius:6px;">View HTML</button>
          </div>
        </div>
        <div id={`ref-huffman-1`} style="margin-top:0.5rem; display:none;">
          <iframe src={`${base}/documents/reflections/html/${encodeURIComponent('Reflection - HuffmanCompression 1.html')}`} style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;" loading="lazy" title="Huffman Reflection"></iframe>
        </div>
      </div>

      <p><a href={`${base}/aden-course`} style="color:#0055aa; text-decoration:underline;">← Back to ADEN Course</a></p>
    </section>
  </section>
</BaseLayout>