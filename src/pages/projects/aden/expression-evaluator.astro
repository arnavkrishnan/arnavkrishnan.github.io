---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
import DocCard from '../../../components/DocCard.astro';

const base = '/portfolio';
const previous = null;
const next = 'elevator';

const htmlFile = 'Reflection -  ExpressionEvaluator.html';
const pdfFile = 'Reflection -  ExpressionEvaluator.pdf';
---

<BaseLayout title="Expression Evaluator | ADEN Project" base={base}>
<Pagination base={base} section="projects/aden" previous={previous} next={next} />
  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">


    <h1>Expression Evaluator</h1>

    {/* DESCRIPTION */}
    <section style="margin-bottom:1rem;">
      <p>
        A parser and evaluator that processes infix arithmetic expressions with correct operator precedence and parentheses support.
        It uses a two-stack system to evaluate expressions step-by-step and detect malformed input.
      </p>
    </section>

    {/* PHASES */}
    <section id="phases" style="margin-bottom:1rem;">
      <h2>Project Phases</h2>
      <ol>
        <li>Define expression grammar and tokenization rules.</li>
        <li>Implement stack-based evaluation with operator precedence.</li>
        <li>Add support for parentheses and nested expressions.</li>
        <li>Implement static error checking (operators, data, parentheses).</li>
        <li>Add implicit multiplication and negative number handling.</li>
        <li>Implement divide-by-zero runtime detection.</li>
      </ol>
    </section>

    {/* ANALYSIS */}
    <section id="analysis" style="margin-bottom:1rem;">
      <h2>Summary of Key Learnings</h2>
      <p>
        The evaluator processes expressions in linear time using stacks. Careful handling of tokenization
        and edge cases like negative numbers significantly improved correctness and usability.
      </p>
    </section>

    {/* REFLECTIONS */}
    <section id="reflections" style="margin-bottom:1rem;">
      <h2>Reflections</h2>

      <DocCard
        title="Expression Evaluator Reflection"
        pdfHref={`${base}/documents/reflections/pdf/${encodeURIComponent(pdfFile)}`}
        htmlHref={`${base}/documents/reflections/html/${encodeURIComponent(htmlFile)}`}
        iframeId="html-view"
        iframeTitle="Expression Evaluator Reflection"
      />

      <p style="margin-top:1rem;">
        <a href={`${base}/projects/aden`} style="color:#0055aa; text-decoration:underline;">
          ← Back to ADEN Course
        </a>
      </p>
    </section>

  </section>
</BaseLayout>