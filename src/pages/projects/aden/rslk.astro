---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
import DocCard from '../../../components/DocCard.astro';
const base = '/portfolio';
const previous = 'hashes';
const next = null;

const reflections = [
  {
    title: 'Line Sensor',
    pdf: 'Reflection -  RSLK Line Sensor.pdf',
    html: 'Reflection -  RSLK Line Sensor.html',
    iframeId: 'ref-line-sensor',
    iframeTitle: 'RSLK Line Sensor'
  },
  {
    title: 'SysTick & Interrupts',
    pdf: 'Reflection -  RSLK - SysTick and Interrupts.pdf',
    html: 'Reflection -  RSLK - SysTick and Interrupts.html',
    iframeId: 'ref-systick',
    iframeTitle: 'RSLK SysTick & Interrupts'
  },
  {
    title: 'Finite State Machines',
    pdf: 'Reflection -  RSLK - Finite State Machines.pdf',
    html: 'Reflection -  RSLK - Finite State Machines.html',
    iframeId: 'ref-fsm',
    iframeTitle: 'RSLK Finite State Machines'
  },
  {
    title: 'Working at a Bit Level',
    pdf: 'Reflection -  Working at a bit level.pdf',
    html: 'Reflection -  Working at a bit level.html',
    iframeId: 'ref-bit-level',
    iframeTitle: 'Working at a Bit Level'
  }
];
---
<BaseLayout title="RSLK Robot | ADEN Project" base={base}>
  <Pagination base={base} section="projects/aden" previous={previous} next={next} />
  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
  <h1>RSLK Robot</h1>

  <section style="margin-bottom:1.5rem;">
    <p>
      The RSLK (Robotics System Learning Kit) project develops a small robot using the Texas Instruments platform. I programmed sensors, motors, timers, and interrupts to enable line following and autonomous navigation. This was my first deep dive into embedded systems programming close to the hardware.
    </p>
  </section>

  <section style="margin-bottom:1.5rem;">
    <h2>Development Components</h2>
    <ul>
      <li><strong>Input/Output:</strong> Processed digital and analog sensor readings, controlled motor outputs via PWM.</li>
      <li><strong>Line Sensor:</strong> Used reflectance sensors that measure discharge time from a capacitor. darker surfaces cause faster discharge (the physics behind this are actually quite interesting).</li>
      <li><strong>Interrupts:</strong> SysTick interrupts used for sensor timing and non-blocking reads.</li>
      <li><strong>Motors:</strong> Motor control tuned for stable line following.</li>
    </ul>
  </section>

  <section style="margin-bottom:1.5rem;">
    <h2>Visuals / Video</h2>
    <video controls style="width:100%; max-width:720px; border:1px solid #ddd; border-radius:12px; background:#000;" src={`${base}/videos/RSLK.mp4`}>
      Your browser does not support video playback.
    </video>
    <p style="margin-top:0.75rem; color:#666;">This video shows Albert's robot driving first, and mine quickly catching up. It is not shown in the recording, due to Albert's questionable videography skills, but my robot did indeed read-end his. My robot was much faster than his because I used a PID (Proportional Integral Derivative) controller and had fine-tuned the values for the maximum speed possible. </p>
  </section>

  <section id="reflection" style="margin-bottom:1.5rem;">
    <h2>Reflections</h2>

    <div style="display:grid; gap:0.6rem;">
      {reflections.map((reflection) => (
        <DocCard
          title={reflection.title}
          pdfHref={`${base}/documents/reflections/pdf/${encodeURIComponent(reflection.pdf)}`}
          htmlHref={`${base}/documents/reflections/html/${encodeURIComponent(reflection.html)}`}
          iframeId={reflection.iframeId}
          iframeTitle={reflection.iframeTitle}
        />
      ))}
    <h2>Navigation</h2>
    <p><a href={`${base}/aden-course`} style="color:#0055aa; text-decoration:underline;">← Back to ADEN Course</a></p>
  </section>
</section>
</BaseLayout>