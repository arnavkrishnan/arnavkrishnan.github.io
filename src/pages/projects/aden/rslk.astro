---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
const base = '/portfolio';
const previous = 'hashes';
const next = null;
---
<BaseLayout title="RSLK Robot | ADEN Project" base={base}>
  <Pagination base={base} section="projects/aden" previous={previous} next={next} />
  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
  <h1>RSLK Robot</h1>

  <section style="margin-bottom:1.5rem;">
    <p>
      The RSLK (Robotics System Learning Kit) project develops a small robot using the Texas Instruments platform. I programmed sensors, motors, timers, and interrupts to enable line following and autonomous navigation. This was my first deep dive into embedded systems programming close to the hardware.
    </p>
  </section>

  <section style="margin-bottom:1.5rem;">
    <h2>Development Components</h2>
    <ul>
      <li><strong>Input/Output:</strong> Processed digital and analog sensor readings, controlled motor outputs via PWM.</li>
      <li><strong>Line Sensor:</strong> Used reflectance sensors that measure discharge time from a capacitor — darker surfaces cause faster discharge.</li>
      <li><strong>Interrupts:</strong> SysTick interrupts used for sensor timing and non-blocking reads.</li>
      <li><strong>Motors:</strong> Motor control tuned for stable line following.</li>
    </ul>
  </section>

  <section style="margin-bottom:1.5rem;">
    <h2>Visuals / Video</h2>
    <video controls style="width:100%; max-width:720px; border:1px solid #ddd; border-radius:12px; background:#000;" src={`${base}/videos/TB_vid_1.mp4`}>
      Your browser does not support video playback.
    </video>
    <p style="margin-top:0.75rem; color:#666;">Demo video of the robot following a black line on white background, using the 8-sensor array and FSM control.</p>
    <img src={`${base}/images/wheel-shaft-drawing.png`} alt="RSLK robot diagram placeholder" style="width:100%; max-width:720px; border-radius:12px; border:1px solid #ddd; margin-top:1rem;" />
  </section>

  <section id="reflection" style="margin-bottom:1.5rem;">
    <h2>Reflections</h2>

    <div style="display:grid; gap:0.6rem;">
      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Line Sensor</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/html/${encodeURIComponent('Reflection -  RSLK Line Sensor.html')}`} target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Open HTML</a>
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Reflection -  RSLK Line Sensor.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
          </div>
        </div>
      </div>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>SysTick & Interrupts</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/html/${encodeURIComponent('Reflection -  RSLK - SysTick and Interrupts.html')}`} target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Open HTML</a>
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Reflection -  RSLK - SysTick and Interrupts.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
          </div>
        </div>
      </div>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Finite State Machines</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/html/${encodeURIComponent('Reflection -  RSLK - Finite State Machines.html')}`} target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Open HTML</a>
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Reflection -  RSLK - Finite State Machines.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
          </div>
        </div>
      </div>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Working at a Bit Level</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/html/${encodeURIComponent('Reflection -  Working at a bit level.html')}`} target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Open HTML</a>
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Reflection -  Working at a bit level.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <h2>Navigation</h2>
    <p><a href={`${base}/aden-course`} style="color:#0055aa; text-decoration:underline;">← Back to ADEN Course</a></p>
  </section>
</section>
</BaseLayout>