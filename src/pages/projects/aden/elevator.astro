---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
const base = '/portfolio';
const previous = 'expression-evaluator';
const next = 'huffman-compression';
---
<BaseLayout title="Elevator | ADEN Project" base={base}>
  <Pagination base={base} section="projects/aden" previous={previous} next={next} />
  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
    <h1>Elevator Control System</h1>

    <section style="margin-bottom:1rem;">
      <p>
        Embedded control project modeling elevators, scheduling, and finite state machines. Focus areas were sensor integration, state transitions, and measuring user-facing metrics such as wait time.
      </p>
    </section>

    <section id="reflections" style="margin-bottom:1rem;">
      <h2>Reflections</h2>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-bottom:0.75rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Elevator Reflection 1</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Elevator Reflection 1.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
            <button type="button" aria-expanded="false" class="toggle-btn" data-target={`ref-elevator-1`} style="padding:0.35rem 0.5rem; border-radius:6px;">View HTML</button>
          </div>
        </div>
        <div id={`ref-elevator-1`} style="margin-top:0.5rem; display:none;">
          <iframe src={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Reflection 1.html')}`} style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;" loading="lazy" title="Elevator Reflection 1"></iframe>
        </div>
      </div>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-bottom:0.75rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Elevator Weekly Reflection 2</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Elevator Weekly Reflection 2.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
            <button type="button" aria-expanded="false" class="toggle-btn" data-target={`ref-elevator-2`} style="padding:0.35rem 0.5rem; border-radius:6px;">View HTML</button>
          </div>
        </div>
        <div id={`ref-elevator-2`} style="margin-top:0.5rem; display:none;">
          <iframe src={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Weekly Reflection 2.html')}`} style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;" loading="lazy" title="Elevator Weekly Reflection 2"></iframe>
        </div>
      </div>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-bottom:0.75rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Elevator Weekly Reflection 3</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Elevator Weekly Reflection 3.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
            <button type="button" aria-expanded="false" class="toggle-btn" data-target={`ref-elevator-3`} style="padding:0.35rem 0.5rem; border-radius:6px;">View HTML</button>
          </div>
        </div>
        <div id={`ref-elevator-3`} style="margin-top:0.5rem; display:none;">
          <iframe src={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Weekly Reflection 3.html')}`} style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;" loading="lazy" title="Elevator Weekly Reflection 3"></iframe>
        </div>
      </div>

      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-bottom:0.75rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Elevator Weekly Reflection 4</strong>
          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a href={`${base}/documents/reflections/pdf/${encodeURIComponent('Elevator Weekly Reflection 4.pdf')}`} download target="_blank" rel="noopener" style="font-size:0.9rem; color:#0b66c3;">Download PDF</a>
            <button type="button" aria-expanded="false" class="toggle-btn" data-target={`ref-elevator-4`} style="padding:0.35rem 0.5rem; border-radius:6px;">View HTML</button>
          </div>
        </div>
        <div id={`ref-elevator-4`} style="margin-top:0.5rem; display:none;">
          <iframe src={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Weekly Reflection 4.html')}`} style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;" loading="lazy" title="Elevator Weekly Reflection 4"></iframe>
        </div>
      </div>

      <p><a href={`${base}/aden-course`} style="color:#0055aa; text-decoration:underline;">← Back to ADEN Course</a></p>
    </section>
  </section>
</BaseLayout>

<script>
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.toggle-btn');
    if (!btn) return;

    const targetId = btn.dataset.target;
    const panel = document.getElementById(targetId);
    if (!panel) return;

    const isOpen = panel.style.display !== 'none';

    panel.style.display = isOpen ? 'none' : 'block';
    btn.textContent = isOpen ? 'View HTML' : 'Hide HTML';
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>