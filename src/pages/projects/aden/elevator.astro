---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';

const base = '/portfolio';
const previous = 'expression-evaluator';
const next = 'huffman-compression';
---

<BaseLayout title="Elevator | ADEN Project" base={base}>
  <Pagination
    base={base}
    section="projects/aden"
    previous={previous}
    next={next}
  />

  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
    <h1>Elevator Control System</h1>

    <section style="margin-bottom:1rem;">
      <h2>Project Description</h2>

      <p>
        Embedded control project modeling elevators, scheduling, and finite
        state machines. Focus areas included sensor integration, state
        transitions, passenger scheduling, and measuring user-facing metrics
        such as wait time, ride time, total travel time, and overall system
        performance.
      </p>
    </section>

    <section id="phases" style="margin-bottom:1rem;">
      <h2>Project Phases</h2>

      <ol>
        <li>Requirements Analysis and Elevator Modeling</li>
        <li>Finite State Machine Design</li>
        <li>Passenger Scheduling and Request Handling</li>
        <li>Simulation Development and Testing</li>
        <li>Performance Analysis</li>
        <li>Configuration Comparison and Recommendation</li>
      </ol>

      <!-- FINAL DESIGN DOC -->
      <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-top:0.75rem;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
          <strong>Elevator Design Document (Final)</strong>

          <div style="display:flex; gap:0.5rem; align-items:center;">
            <a
              href={`${base}/documents/ADEN_docs/pdf/${encodeURIComponent(
                'Elevator Simulation Updog Design Document, vFinal.pdf'
              )}`}
              download
              target="_blank"
              rel="noopener"
              style="font-size:0.9rem; color:#0b66c3;"
            >
              Download PDF
            </a>

            <button
              type="button"
              class="toggle-btn"
              data-target="design-final"
              style="padding:0.35rem 0.5rem; border-radius:6px;"
            >
              View HTML
            </button>
          </div>
        </div>

        <div id="design-final" style="margin-top:0.5rem; display:none;">
          <iframe
            src={`${base}/documents/ADEN_docs/html/Elevator Simulation Updog Design Document, vFinal/ElevatorSimulationUpdogDesignDocumentvFinal.html`}
            style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;"
            loading="lazy"
            title="Elevator Design Document Final"
          ></iframe>
        </div>
      </div>

      <!-- DESIGN DOCS V1 -->
      <div style="margin-top:1.25rem;">
        <h3>Design Document Versions</h3>

        <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-top:0.75rem;">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
            <strong>Design Document v1</strong>

            <div style="display:flex; gap:0.5rem; align-items:center;">
              <a
                href={`${base}/documents/ADEN_docs/pdf/${encodeURIComponent(
                  'Elevator Simulation Updog Design Document, v1.pdf'
                )}`}
                download
                target="_blank"
                rel="noopener"
                style="font-size:0.9rem; color:#0b66c3;"
              >
                Download PDF
              </a>

              <button
                type="button"
                class="toggle-btn"
                data-target="design-v1"
                style="padding:0.35rem 0.5rem; border-radius:6px;"
              >
                View HTML
              </button>
            </div>
          </div>

          <div id="design-v1" style="margin-top:0.5rem; display:none;">
            <iframe
              src={`${base}/documents/ADEN_docs/html/Elevator Simulation Updog Design Document, v1/ElevatorSimulationUpdogDesignDocumentv1.html`}
              style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;"
              loading="lazy"
              title="Design Document v1"
            ></iframe>
          </div>
        </div>

        <!-- DESIGN DOC V2 -->
        <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-top:0.75rem;">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
            <strong>Design Document v2</strong>

            <div style="display:flex; gap:0.5rem; align-items:center;">
              <a
                href={`${base}/documents/ADEN_docs/pdf/${encodeURIComponent(
                  'Elevator Simulation Updog Design Document, v2.pdf'
                )}`}
                download
                target="_blank"
                rel="noopener"
                style="font-size:0.9rem; color:#0b66c3;"
              >
                Download PDF
