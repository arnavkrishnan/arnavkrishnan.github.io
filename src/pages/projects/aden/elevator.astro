          style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;"
          loading="lazy"
          title="Elevator Weekly Reflection 2"
        ></iframe>
      </div>
    </div>

    <!-- Reflection 3 -->
    <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-top:0.75rem;">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
        <strong>Elevator Weekly Reflection 3</strong>

        <div style="display:flex; gap:0.5rem; align-items:center;">
          <a
            href={`${base}/documents/reflections/pdf/${encodeURIComponent('Elevator Weekly Reflection 3.pdf')}`}
            download
            target="_blank"
            rel="noopener"
            style="font-size:0.9rem; color:#0b66c3;"
          >
            Download PDF
          </a>

          <button
            type="button"
            class="toggle-btn"
            data-target="ref-3"
            style="padding:0.35rem 0.5rem; border-radius:6px;"
          >
            View HTML
          </button>
        </div>
      </div>

      <div id="ref-3" style="margin-top:0.5rem; display:none;">
        <iframe
          src={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Weekly Reflection 3.html')}`}
          style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;"
          loading="lazy"
          title="Elevator Weekly Reflection 3"
        ></iframe>
      </div>
    </div>

    <!-- Reflection 4 -->
    <div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-top:0.75rem;">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
        <strong>Elevator Weekly Reflection 4</strong>

        <div style="display:flex; gap:0.5rem; align-items:center;">
          <a
