---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
import DocCard from '../../../components/DocCard.astro';

const base = '/portfolio';
const previous = 'expression-evaluator';
const next = 'huffman-compression';

const designDocs = [
  {
    title: 'Elevator Design Document (Final)',
    pdf: 'Elevator Simulation Updog Design Document, vFinal.pdf',
    html: 'Elevator Simulation Updog Design Document, vFinal/ElevatorSimulationUpdogDesignDocumentvFinal.html',
    iframeId: 'design-final',
    iframeTitle: 'Elevator Design Document Final'
  },
  {
    title: 'Design Document v1',
    pdf: 'Elevator Simulation Updog Design Document, v1.pdf',
    html: 'Elevator Simulation Updog Design Document, v1/ElevatorSimulationUpdogDesignDocumentv1.html',
    iframeId: 'design-v1',
    iframeTitle: 'Elevator Design Document v1'
  },
  {
    title: 'Design Document v2',
    pdf: 'Elevator Simulation Updog Design Document, v2.pdf',
    html: 'Elevator Simulation Updog Design Document, v2/ElevatorSimulationUpdogDesignDocumentv2.html',
    iframeId: 'design-v2',
    iframeTitle: 'Elevator Design Document v2'
  }
];

const reflections = [
  {
    title: 'Elevator Reflection 1',
    pdf: 'Elevator Reflection 1.pdf',
    html: 'Elevator Reflection 1.html',
    iframeId: 'ref-1',
    iframeTitle: 'Elevator Reflection 1'
  },
  {
    title: 'Elevator Weekly Reflection 2',
    pdf: 'Elevator Weekly Reflection 2.pdf',
    html: 'Elevator Weekly Reflection 2.html',
    iframeId: 'ref-2',
    iframeTitle: 'Elevator Weekly Reflection 2'
  },
  {
    title: 'Elevator Weekly Reflection 3',
    pdf: 'Elevator Weekly Reflection 3.pdf',
    html: 'Elevator Weekly Reflection 3.html',
    iframeId: 'ref-3',
    iframeTitle: 'Elevator Weekly Reflection 3'
  },
  {
    title: 'Elevator Weekly Reflection 4',
    pdf: 'Elevator Weekly Reflection 4.pdf',
    html: 'Elevator Weekly Reflection 4.html',
    iframeId: 'ref-4',
    iframeTitle: 'Elevator Weekly Reflection 4'
  }
];
---

<BaseLayout title="Elevator | ADEN Project" base={base}>
  <Pagination
    base={base}
    section="projects/aden"
    previous={previous}
    next={next}
  />

  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
    <h1>Elevator Project</h1>

    <section style="margin-bottom:1rem;">
      <h2>Project Description</h2>

      <p>
        Embedded project modeling elevators, scheduling, and finite
        state machines. Focus areas included sensor integration, state
        transitions, passenger scheduling, and measuring user-facing metrics
        such as wait time, ride time, total travel time, and overall system
        performance.
      </p>
    </section>

    <section id="phases" style="margin-bottom:1rem;">
      <h2>Project Phases</h2>

      <ol>
        <li>Requirements Analysis and Elevator Modeling</li>
        <li>Finite State Machine Design</li>
        <li>Passenger Scheduling and Request Handling</li>
        <li>Simulation Development and Testing</li>
        <li>Performance Analysis</li>
        <li>Configuration Comparison and Recommendation</li>
      </ol>

      <div style="margin-top:1.25rem;">
        <h3>Design Documents</h3>

        {designDocs.map((doc) => (
          <DocCard
            title={doc.title}
            pdfHref={`${base}/documents/ADEN_docs/pdf/${encodeURIComponent(doc.pdf)}`}
            htmlHref={`${base}/documents/ADEN_docs/html/${doc.html}`}
            iframeId={doc.iframeId}
            iframeTitle={doc.iframeTitle}
          />
        ))}
      </div>
    </section>

    <!-- ANALYSIS -->
    <section id="analysis" style="margin-bottom:1rem;">
      <h2>Summary of Analysis</h2>

      <p>During analysis, three elevator configurations were compared:</p>

      <ul>
        <li>Capacity = 15, floorTicks = 5, doorTicks = 2, passPerTick = 3</li>
        <li>Capacity = 20, floorTicks = 7, doorTicks = 3, passPerTick = 4</li>
        <li>Capacity = 10, floorTicks = 3, doorTicks = 2, passPerTick = 3</li>
      </ul>

      <p>
        We evaluated completion rate, average wait time, average total time,
        weighted passenger travel time, ride time per floor, and standard deviation metrics.
      </p>

      <p>
        All three elevators achieved excellent completion rates, but
        Configuration 3 consistently provided the fastest service and most reliable passenger experience.
      </p>

      <p>
        Although Configuration 3 had the smallest capacity, its faster movement
        and higher throughput outweighed the larger designs.
      </p>
    </section>

    <!-- LEARNINGS -->
    <section id="learnings" style="margin-bottom:1rem;">
      <h2>Key Learnings</h2>

      <ul>
        <li>Finite state machines provide a structured framework for embedded control systems.</li>
        <li>Data-driven analysis is essential when comparing competing designs.</li>
        <li>Smaller-capacity systems can outperform larger systems when optimized for throughput.</li>
        <li>User-facing metrics such as wait time and consistency are critical indicators of quality.</li>
        <li>Simulation is a valuable engineering tool for evaluating designs before deployment.</li>
      </ul>
    </section>

    <!-- REFLECTIONS -->
    <section id="reflections" style="margin-bottom:1rem;">
      <h2>Reflections</h2>

      {reflections.map((reflection) => (
        <DocCard
          title={reflection.title}
          pdfHref={`${base}/documents/reflections/pdf/${encodeURIComponent(reflection.pdf)}`}
          htmlHref={`${base}/documents/reflections/html/${encodeURIComponent(reflection.html)}`}
          iframeId={reflection.iframeId}
          iframeTitle={reflection.iframeTitle}
        />
      ))}

      <p style="margin-top:1rem;">
        <a href={`${base}/projects/aden`} style="color:#0055aa; text-decoration:underline;">
          ← Back to ADEN Course
        </a>
      </p>
    </section>
  </section>
</BaseLayout>