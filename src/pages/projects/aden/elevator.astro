---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Pagination from '../../../components/Pagination.astro';
const base = '/portfolio';
const previous = 'expression-evaluator';
const next = 'huffman-compression';
---
<BaseLayout title="Elevator | ADEN Project" base={base}>
  <Pagination base={base} section="projects/aden" previous={previous} next={next} />
  <h1>Elevator Control System</h1>

  <section style="margin-bottom:1rem;">
    <p>
      Embedded control project modeling elevators, scheduling, and finite state machines. Focus areas were sensor integration, state transitions, and measuring user-facing metrics such as wait time.
    </p>
  </section>
  </section>

  <section id="reflections" style="margin-bottom:1rem;">
    <h2>Reflections</h2>
    <p>
      <strong>Reflections:</strong>
      <a href={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Reflection 1.html')}`} target="_blank" rel="noopener">#1</a>
      {' '}|{' '}
      <a href={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Weekly Reflection 2.html')}`} target="_blank" rel="noopener">#2</a>
      {' '}|{' '}
      <a href={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Weekly Reflection 3.html')}`} target="_blank" rel="noopener">#3</a>
      {' '}|{' '}
      <a href={`${base}/documents/reflections/html/${encodeURIComponent('Elevator Weekly Reflection 4.html')}`} target="_blank" rel="noopener">#4</a>
