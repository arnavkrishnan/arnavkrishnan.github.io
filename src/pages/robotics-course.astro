---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '';
---
<BaseLayout title="Robotics Course" base={base}>
  <section style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
  <h1>Robotics I</h1>
  <p>I took this Robotics I course in 10th grade and earned an overall grade of A.</p>
  <p>This course included hands-on robotics work, team problem solving, and engineering design concepts. It is taught by Mr. Stephen Hine. It is a prerequisite for Robotics II, the robotics travel team.</p>
  <ul>
    <li><a href={`${base}/projects/robotics`}>Robotics Projects</a></li>
    <li><a href={`${base}/certifications`}>Certifications</a></li>
  </ul>
</section>
</BaseLayout>
