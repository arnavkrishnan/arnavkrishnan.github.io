---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

const base = '';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = posts[0];
const { Content } = latest ? await render(latest) : { Content: null };

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---
<BlogLayout title="What's New" base={base} activeId={latest?.id}>
  {latest ? (
    <>
      <h1>{latest.data.title}</h1>
      <p class="post-meta">
        {fmt(latest.data.date)}
        {latest.data.tags.length > 0 && (
          <span class="post-tags">
            {latest.data.tags.map((tag) => (
              <a class="tag" href={`${base}/blog/tags/${tag.toLowerCase()}`}>{tag}</a>
            ))}
          </span>
        )}
      </p>

      <Content />
    </>
  ) : (
    <>
      <h1>What&rsquo;s New</h1>
      <p class="post-meta">Ad hoc notes &amp; updates</p>
      <p>No posts yet.</p>
    </>
  )}
</BlogLayout>
