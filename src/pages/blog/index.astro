---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

const base = '';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = posts[0];
const { Content } = latest ? await render(latest) : { Content: null };

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
const older = posts[1] ?? null;
---
<BlogLayout title="What's New" base={base} activeId={latest?.id}>
  <h1>What&rsquo;s New</h1>
  <p class="post-meta">Ad hoc notes &amp; updates</p>
  <p>
    A running collection of short notes, with no particular rhyme or reason.
  </p>

  <hr />

  {latest ? (
    <>
      <h2>{latest.data.title}</h2>
      <p class="post-meta">
        {fmt(latest.data.date)}
        {latest.data.tags.length > 0 && (
          <span class="post-tags">
            {latest.data.tags.map((tag) => (
              <a class="tag" href={`${base}/blog/tags/${tag.toLowerCase()}`}>{tag}</a>
            ))}
          </span>
        )}
      </p>

      <Content />

      <hr style="margin-top:2.5rem;" />
      <nav class="post-nav">
        <span>
          {older && <a href={`${base}/blog/${older.id}`}>&larr; {older.data.title}</a>}
        </span>
        <span></span>
      </nav>
    </>
  ) : (
    <p>No posts yet.</p>
  )}

  <style>
    .post-nav {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      font-size: 0.9rem;
    }
    .post-nav span {
      max-width: 48%;
    }
  </style>
</BlogLayout>
