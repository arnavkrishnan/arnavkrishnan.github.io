---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/portfolio';
---

<BaseLayout title="About Me" base={base}>
  <h1>About Me</h1>
  <p>
  I am a student at
  <a href="https://lahs.mvla.net" target="_blank" rel="noopener">
    Los Altos High School
  </a>
  (class of 2028). I like
  <a href="https://en.wikipedia.org/wiki/Mathematics" target="_blank" rel="noopener">
    mathematics
  </a>.
</p>
  <p>Feel free to contact me via the methods below:</p>

  <section>
    <h2>Contact</h2>
    <ul style="list-style: none; padding: 0;">
      <li style="margin-bottom: 0.5rem;">
        Email: 
        <a id="email-link"></a>

<script>
const user = "arnav.s.krishnan";
const domain = "gmail.com";

const email = `${user}@${domain}`;
const link = document.getElementById("email-link");

link.href = `mailto:${email}`;
link.textContent =
  "arnav dot s dot krishnan at gmail dot com";
</script>
<small>(obfuscated to reduce spam)</small>
        <button class="copy-btn" data-copy="arnav.s.krishnan@gmail.com">Copy</button>
      </li>
      <li>
        GitHub: 
        <a href="https://github.com/arnavkrishnan" target="_blank" rel="noopener">github.com/arnavkrishnan</a>
      </li>
    </ul>
  </section>

  <script type="module">
    // Select all copy buttons
    const buttons = document.querySelectorAll('.copy-btn');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.dataset.copy;

        navigator.clipboard.writeText(text).then(() => {
          const original = btn.textContent;

          // Fade to thumbs-up
          btn.textContent = '👍';
          btn.style.opacity = 0;
          btn.style.transition = 'opacity 0.2s';
          requestAnimationFrame(() => btn.style.opacity = 1);

          // Revert after 1 second with fade
          setTimeout(() => {
            btn.style.opacity = 0;
            setTimeout(() => {
              btn.textContent = original;
              btn.style.opacity = 1;
            }, 200);
          }, 1000);
        });
      });
    });
  </script>
</BaseLayout>
