---
const { base, currentPath } = Astro.props;

function isActive(path: string) {
  return currentPath === `${base}${path}` ? 'font-weight: bold; text-decoration: underline;' : '';
}
---
<nav>
  <a href={`${base}/`} style={isActive('/')}>Home</a>
  <a href={`${base}/blog`} style={currentPath.startsWith(`${base}/blog`) ? 'font-weight: bold; text-decoration: underline;' : ''}>Blog</a>
</nav>
<hr />

<style>
  nav a {
    color: inherit;
    text-decoration: none;
    margin-right: 1rem;
  }
  nav a:hover {
    text-decoration: underline;
  }
</style>