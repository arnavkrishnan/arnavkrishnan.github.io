---
const { base, currentPath } = Astro.props;

function isActive(path: string) {
  return currentPath === `${base}${path}` ? 'font-weight: bold; text-decoration: underline;' : '';
}
---
<nav>
  <a href={`${base}/`} style={isActive('/')}>Home</a>
  <span style="margin-left: 0.5rem; font-weight:700;">Robotics:</span>
  <a href={`${base}/robotics-course`} style={isActive('/robotics-course')}>Course</a>
  <a href={`${base}/projects/robotics`} style={isActive('/projects/robotics')}>Projects</a>
  <a href={`${base}/certifications`} style={isActive('/certifications')}>Certifications</a>

  <span style="margin-left: 0.5rem; font-weight:700;">ADEN:</span>
  <a href={`${base}/aden-course`} style={isActive('/aden-course')}>Course</a>
  <a href={`${base}/projects/aden`} style={isActive('/projects/aden')}>Projects</a>
</nav>
<hr />

<style>
  nav a {
    color: inherit;
    text-decoration: none;
    margin-right: 1rem;
  }
  nav a:hover {
    text-decoration: underline;
  }
</style>