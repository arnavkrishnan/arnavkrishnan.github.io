---
import { getCollection } from 'astro:content';

const { base = '', activeId } = Astro.props;

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
---
<aside class="blog-sidebar">
  <h2 class="blog-sidebar-title">
    <a href={`${base}/blog`}>What&rsquo;s New</a>
  </h2>
  <p class="blog-sidebar-tagline">ad hoc notes &amp; updates</p>
  <nav>
    <ul>
      {posts.map((post) => (
        <li class={post.id === activeId ? 'active' : ''}>
          <a href={`${base}/blog/${post.id}`}>{post.data.title}</a>
          <div class="date">{fmt(post.data.date)}</div>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .blog-sidebar {
    font-size: 0.95rem;
  }
  .blog-sidebar-title {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
  }
  .blog-sidebar-title a {
    color: inherit;
    text-decoration: none;
  }
  .blog-sidebar-title a:hover {
    text-decoration: underline;
  }
  .blog-sidebar-tagline {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    color: #666;
    font-style: italic;
  }
  .blog-sidebar nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .blog-sidebar nav li {
    margin-bottom: 0.85rem;
    line-height: 1.3;
  }
  .blog-sidebar nav li a {
    color: inherit;
  }
  .blog-sidebar nav li.active a {
    font-weight: bold;
  }
  .blog-sidebar .date {
    font-size: 0.75rem;
    color: #666;
  }
</style>
