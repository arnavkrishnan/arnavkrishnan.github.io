---
const { base, section, previous, next, listHref } = Astro.props;

function resolveLink(item) {
  if (!item) return null;
  if (typeof item === 'string') {
    return `${base}/${section}/${item}`;
  }
  if (typeof item === 'object' && item.link) {
    return item.link;
  }
  if (typeof item === 'object' && item.slug) {
    return `${base}/${section}/${item.slug}`;
  }
  return null;
}

function resolveLabel(item, defaultLabel) {
  if (!item) return defaultLabel;
  if (typeof item === 'string') return defaultLabel;
  if (typeof item === 'object' && item.title) return item.title;
  return defaultLabel;
}

const previousLink = resolveLink(previous);
const nextLink = resolveLink(next);
const previousLabel = resolveLabel(previous, '← Previous');
const nextLabel = resolveLabel(next, 'Next →');
const listLink = listHref || `${base}/${section}`;
---
<nav class="pagination">
  {previousLink ? (
    <a href={previousLink}>{previousLabel}</a>
  ) : (
    <span class="disabled">← Previous</span>
  )}
  
  <a href={listLink}>List</a>
  
  {nextLink ? (
    <a href={nextLink}>{nextLabel}</a>
  ) : (
    <span class="disabled">Next →</span>
  )}
</nav>
<hr />

<style>
  .pagination {
    display: flex;
    gap: 1rem;
    margin: 1rem 0;
  }
  
  .pagination a {
    color: inherit;
    text-decoration: none;
  }
  
  .pagination a:hover {
    text-decoration: underline;
  }
  
  .pagination .disabled {
    color: #999;
    cursor: not-allowed;
  }
</style>