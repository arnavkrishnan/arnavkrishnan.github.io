---
const slugify = (value) =>
  String(value)
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');

const {
  title,
  pdfHref,
  htmlHref,
  iframeId = slugify(title),
  iframeTitle = title
} = Astro.props;

const hasHtml = Boolean(htmlHref);
---

<div style="border:1px solid #eee; padding:0.75rem; border-radius:8px; margin-top:0.75rem;">
  <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
    <strong>{title}</strong>

    <div style="display:flex; gap:0.5rem; align-items:center;">
      <a
        href={pdfHref}
        download
        target="_blank"
        rel="noopener"
        style="font-size:0.9rem; color:#0b66c3;"
      >
        Download PDF
      </a>

      {hasHtml ? (
        <button
          type="button"
          aria-expanded="false"
          class="toggle-btn"
          data-target={iframeId}
          style="padding:0.35rem 0.5rem; border-radius:6px;"
        >
          View HTML
        </button>
      ) : null}
    </div>
  </div>

  {hasHtml ? (
    <div id={iframeId} style="margin-top:0.5rem; display:none;">
      <iframe
        src={htmlHref}
        style="width:100%; height:520px; border:1px solid #ddd; border-radius:6px;"
        loading="lazy"
        title={iframeTitle}
      />
    </div>
  ) : null}
</div>